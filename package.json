  "version": "0.1.0",
  "description": "Convert documents to PDF using WASM engines — no native dependencies",
  "type": "module",
  "bin": {
    "bentopdf": "./bin/bentopdf.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
